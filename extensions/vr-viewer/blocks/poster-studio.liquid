{% if template == 'product' and product != blank %}

  {% assign feat = product.featured_image %}
  {% if feat != blank %}
    {% assign img = feat | image_url: width: 2048 %}
    {% assign img_thumb = feat | image_url: width: 160, height: 120, crop: 'center' %}
  {% else %}
    {% assign img = '' %}
    {% assign img_thumb = '' %}
  {% endif %}
  {% assign title = product.title | escape %}
  {% assign backend = '/apps/ar-preview' %}

  <div id="ps-root"
    data-product-id="{{ product.id }}"
    data-title="{{ title }}"
    data-img="{{ img }}"
    data-img-thumb="{{ img_thumb }}"
    data-img-w="{{ feat.width | default: 0 }}"
    data-img-h="{{ feat.height | default: 0 }}"
    data-backend="{{ backend | escape }}"
    data-shop="{{ shop.permanent_domain | escape }}"
    data-viewer-src="{{ 'poster-studio-3d-viewer.js' | asset_url }}"
    data-swatch-unframed="https://cdn.shopify.com/s/files/1/0854/9528/3995/files/unframed-poster_265364e4-1c37-44f9-aaf9-e12640e59189.jpg?v=1759858710"
    data-swatch-natural="https://stylemywall.com.au/cdn/shop/files/A_oak_thin_frame_1_400x500.png?v=1767117668"
    data-swatch-natural-landscape="https://stylemywall.com.au/cdn/shop/files/FINAL_PDP_frame_mockup_-_landscape_A_natural_-_Copy_400x500.png?v=1767118551"
    data-swatch-white="https://cdn.shopify.com/s/files/1/0854/9528/3995/files/white-frame_fcb131dc-2809-4931-87f0-fe2d88c466ec.jpg?v=1759905480"
    data-swatch-black="https://cdn.shopify.com/s/files/1/0854/9528/3995/files/black-frame_35a5992e-6f7f-4338-97ec-a177bdd999bd.jpg?v=1759905480"
  ></div>

  <script type="application/json" id="ps-product-data">
  {
    "options": {{ product.options | json }},
    "images": [
      {%- for image in product.images -%}
        {
          "alt": {{ image.alt | json }},
          "src": {{ image | image_url: width: 2048 | json }},
          "thumb": {{ image | image_url: width: 160, height: 120, crop: 'center' | json }},
          "width": {{ image.width | default: 0 }},
          "height": {{ image.height | default: 0 }}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ],
    "variants": [
      {%- for variant in product.variants -%}
        {
          "id": {{ variant.id }},
          "options": {{ variant.options | json }},
          "featured_image": {% if variant.featured_image %}{
            "src": {{ variant.featured_image | image_url: width: 2048 | json }},
            "width": {{ variant.featured_image.width | default: 0 }},
            "height": {{ variant.featured_image.height | default: 0 }}
          }{% else %}null{% endif %}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  }
  </script>

  {{ 'poster-studio.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'poster-studio.js' | asset_url }}" defer></script>

{% endif %}

{% schema %}
{
  "name": "Poster Studio",
  "target": "body",
  "templates": ["product"],
  "settings": []
}
{% endschema %}
