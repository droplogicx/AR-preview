{% if template == 'product' and product != blank %}

  {% assign img    = product.featured_image | img_url: 'master' %}
  {% assign title  = product.title | escape %}
  {% assign app    = block.settings.backend_url %}
  {% assign width  = product.metafields.ar_viewer.width_cm  | default: '60' %}
  {% assign height = product.metafields.ar_viewer.height_cm | default: '40' %}

  <div id="ar-root"
    data-title="{{ title }}"
    data-img="{{ img }}"
    data-backend="{{ app }}"
    data-width="{{ width }}"
    data-height="{{ height }}"
  ></div>

  {{ 'ar.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'ar.js' | asset_url }}" defer></script>

{% endif %}

{% schema %}
{
  "name": "VR Viewer",
  "target": "body",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "backend_url",
      "label": "Backend URL",
      "info": "Your Remix app URL e.g. https://your-app.railway.app"
    }
  ]
}
{% endschema %}
